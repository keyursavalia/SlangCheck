# Xcode build artifacts
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods (not used, but just in case)
Pods/
Podfile.lock

# ──────────────────────────────────────────────────────────────────────────────
# SECRETS — NEVER COMMIT ANY OF THESE FILES.
# If any of these ever appear in `git status` as untracked, do NOT `git add .`
# Add them explicitly by name only and verify nothing sensitive is staged.
# ──────────────────────────────────────────────────────────────────────────────

# Firebase configuration plist — contains API keys, project IDs, and client IDs.
# Add to Xcode target manually. Share with teammates via a secrets manager, NOT git.
GoogleService-Info.plist
**/GoogleService-Info.plist
SlangCheck/GoogleService-Info.plist

# Firebase service account JSON — grants admin access to all Firebase services.
# Used only for CI/CD scripts, stored exclusively in CI secret vaults.
*-service-account.json
service-account*.json
firebase-adminsdk*.json

# Secrets plist — contains Gemini API key. Never commit.
Secrets.plist
**/Secrets.plist

# Xcconfig files that may contain injected secrets (API keys, bundle IDs, etc.)
Secrets.xcconfig
*.xcconfig.local
*.xcconfig.secret

# Local Firebase CLI state — not sensitive but project-specific, don't share.
.firebaserc
firebase.json

# Firebase emulator data (local dev only)
.firebase/
firebase-export-*/

# Environment variable files (if ever used for local scripts)
.env
.env.local
.env.*.local

# Apple private key downloads (.p8 files) — used for APNs / Sign in with Apple.
# Download once, store in a password manager. If lost, generate a new one.
*.p8
AuthKey_*.p8

# Local developer documentation that may contain secrets, keys, or internal notes.
FIREBASE_SETUP.md

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# User-specific Xcode settings
*.xccheckout
*.moved-aside
xcuserdata/

# Fastlane (if added later)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# TestFlight / App Store
*.ipa
*.mobileprovision

# Instruments
*.trace
SCREENS/
noticia-text/
# Internal planning docs — not for version control
MVP.md
